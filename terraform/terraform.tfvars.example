# Example values for REQUIRED, NON-secret variables (no default in variables.tf).
# Copy to terraform.auto.tfvars and fill in real values -- do NOT commit that file.
#
# Sensitive variables are deliberately NOT listed here. Supply them via:
#   - TF_VAR_<name> environment variables, or
#   - a gitignored *.auto.tfvars file, or
#   - your CI/CD pipeline's secret store (GitHub Actions secrets, Vault, etc.)
#
# Sensitive variables used by this project:
#   cache1_auth_token  (export TF_VAR_cache1_auth_token=... )
#   rds1_password  (export TF_VAR_rds1_password=... )

cdn1_origin_domain_name = "REPLACE_ME"
data1_availability_zone = "REPLACE_ME"
data1_cidr_block = "REPLACE_ME"
dns1_domain_name = "REPLACE_ME"
ec2_auto1_execution_role_arn = "REPLACE_ME"
ec2_auto1_package_s3_bucket = "REPLACE_ME"
ec2_auto1_package_s3_key = "REPLACE_ME"
lambda1_execution_role_arn = "REPLACE_ME"
lambda1_package_s3_bucket = "REPLACE_ME"
lambda1_package_s3_key = "REPLACE_ME"
private1_availability_zone = "REPLACE_ME"
private1_cidr_block = "REPLACE_ME"
public1_availability_zone = "REPLACE_ME"
public1_cidr_block = "REPLACE_ME"
rds1_username = "REPLACE_ME"
s3_images_bucket_name = "REPLACE_ME"
